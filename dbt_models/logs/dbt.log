    CAST(onboarded_date AS DATE)                AS onboarded_date,
    CAST(annual_spend_usd AS DOUBLE)            AS annual_spend_usd,
    CAST(_ingested_at AS TIMESTAMP)             AS ingested_at
FROM source
WHERE supplier_id IS NOT NULL
